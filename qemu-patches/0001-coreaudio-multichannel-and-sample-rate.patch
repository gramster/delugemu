-    core->buffer_count = cpdo->has_buffer_count ? cpdo->buffer_count : 4;
+    /*
+     * Default to 8 device periods rather than 4. The IOProc consumes one
+     * period per callback on the real-time audio thread, while QEMU refills
+     * the HW buffer from the main loop (audio_run -> mixeng). The main loop is
+     * periodically blocked for a few milliseconds by the Cocoa display redraw,
+     * during which the IOProc keeps draining; a deeper default buffer gives
+     * that refill more slack so the device buffer does not approach empty on
+     * low-latency devices. Users can still override via the audiodev
+     * buffer-count option.
+     */
+    core->buffer_count = cpdo->has_buffer_count ? cpdo->buffer_count : 8;
 
