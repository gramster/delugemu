+}
+
 static void coreaudio_logstatus(OSStatus status)
 {
     const char *str = "BUG";
@@ -335,20 +347,68 @@ static OSStatus out_device_ioproc(
         return 0;
     }
 
-    len = frame_size * hw->info.bytes_per_frame;
-    while (len) {
-        size_t write_len, start;
-
-        start = audio_ring_posb(hw->pos_emul, hw->pending_emul, hw->size_emul);
-        assert(start < hw->size_emul);
-
-        write_len = MIN(MIN(hw->pending_emul, len),
-                        hw->size_emul - start);
-
-        memcpy(out, hw->buf_emul + start, write_len);
-        hw->pending_emul -= write_len;
-        len -= write_len;
-        out += write_len;
+    {
+        /*
+         * The device may expose more (or fewer) channels than we render. QEMU
+         * asks the device to adopt our channel count, but some hardware (e.g.
+         * multichannel pro interfaces) silently keeps its native layout, so the
+         * IOProc buffer can have a wider frame than hw->info.bytes_per_frame.
+         * Compare the buffer's actual frame stride to ours: if they match, copy
+         * the block straight through (fast path); otherwise place each of our
+         * frames into the first channels of the device frame and silence the
+         * rest, frame by frame, so stereo plays correctly on the first two
+         * outputs instead of being smeared across the channel layout.
+         */
+        const AudioBuffer *ab = &outOutputData->mBuffers[0];
+        UInt32 hw_frame = hw->info.bytes_per_frame;
+        UInt32 dev_frame = ab->mNumberChannels *
+                           (UInt32)(hw_frame / hw->info.nchannels);
+
+        if (dev_frame == 0 || dev_frame == hw_frame) {
+            len = frame_size * hw_frame;
+            while (len) {
+                size_t write_len, start;
+
+                start = audio_ring_posb(hw->pos_emul, hw->pending_emul,
+                                        hw->size_emul);
+                assert(start < hw->size_emul);
+
+                write_len = MIN(MIN(hw->pending_emul, len),
+                                hw->size_emul - start);
+
+                memcpy(out, hw->buf_emul + start, write_len);
+                hw->pending_emul -= write_len;
+                len -= write_len;
+                out += write_len;
+            }
+        } else {
+            UInt32 copy = MIN(hw_frame, dev_frame);
+            UInt32 f;
+
+            /* Silence channels we do not drive (and any frames we skip). */
+            memset(out, 0, (size_t)frame_size * dev_frame);
+
+            for (f = 0; f < frame_size; f++) {
+                uint8_t *dst = (uint8_t *)out + (size_t)f * dev_frame;
+                size_t start;
+
+                if (hw->pending_emul < hw_frame) {
+                    break;
+                }
+                start = audio_ring_posb(hw->pos_emul, hw->pending_emul,
+                                        hw->size_emul);
+                assert(start < hw->size_emul);
+
+                if (hw->size_emul - start >= copy) {
+                    memcpy(dst, hw->buf_emul + start, copy);
+                } else {
+                    size_t first = hw->size_emul - start;
+                    memcpy(dst, hw->buf_emul + start, first);
+                    memcpy(dst + first, hw->buf_emul, copy - first);
+                }
+                hw->pending_emul -= hw_frame;
+            }
+        }
     }
 
