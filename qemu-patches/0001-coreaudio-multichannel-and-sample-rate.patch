+
+    /*
+     * Adopt the output device's current sample rate instead of forcing the
+     * device to ours. Some hardware (HDMI sinks, pro interfaces) silently
+     * refuses a rate change and keeps its native rate, which would leave our
+     * stream playing at the wrong clock (severe pitch/dropout distortion). By
+     * matching hw->info.freq to the device, QEMU's mixeng resamples our source
+     * rate to the device rate cleanly. If the query fails, fall back to the
+     * requested rate.
+     */
+    {
+        AudioDeviceID did;
+        Float64 dev_rate;
+        if (coreaudio_get_voice_out(&did) == kAudioHardwareNoError &&
+            did != kAudioDeviceUnknown &&
+            coreaudio_get_out_nominal_rate(did, &dev_rate) ==
+                kAudioHardwareNoError &&
+            dev_rate > 0) {
+            as->freq = (int)(dev_rate + 0.5);
+        }
+    }
+
     audio_pcm_init_info(&hw->info, as);
 
